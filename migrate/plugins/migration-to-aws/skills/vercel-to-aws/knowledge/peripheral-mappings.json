{
  "description": "Vercel peripheral -> AWS target mapping table (Requirement 8.6). Loaded by scaffold-peripherals.md, always runs regardless of recommended outcome.",
  "mappings": [
    {
      "vercel": "Blob",
      "aws_target": "S3",
      "keep_alternative": null
    },
    {
      "vercel": "Cron",
      "aws_target": "EventBridge Scheduler",
      "keep_alternative": null
    },
    {
      "vercel": "KV",
      "aws_target": "ElastiCache",
      "keep_alternative": "Upstash (often correct to keep)"
    },
    {
      "vercel": "Postgres",
      "aws_target": "RDS / Aurora",
      "keep_alternative": "Neon (often correct to keep)"
    },
    {
      "vercel": "Edge Config",
      "aws_target": "Parameter Store / AppConfig",
      "keep_alternative": null
    },
    {
      "vercel": "Env vars",
      "aws_target": "Secrets Manager / SSM",
      "keep_alternative": null
    }
  ]
}
